# Copy this file to .env and adjust if needed:  cp .env.example .env

# ============ MinIO ============
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=password

# ============ AWS / S3A (point to MinIO) ============
AWS_ACCESS_KEY_ID=admin
AWS_SECRET_ACCESS_KEY=password
AWS_REGION=us-east-1
S3_ENDPOINT=http://minio:9000

# ============ Postgres (shared backend) ============
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow

# ============ Hive Metastore DB ============
HIVE_DB=metastore
HIVE_DB_USER=hive
HIVE_DB_PASSWORD=hive

# ============ Superset DB ============
SUPERSET_DB=superset

# ============ Source (simulated OLTP) DB ============
SOURCE_DB=olist_source

# ============ Airflow ============
AIRFLOW_UID=50000
AIRFLOW__CORE__FERNET_KEY=
AIRFLOW__CORE__EXECUTOR=LocalExecutor
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=admin

# ============ Spark ============
SPARK_MASTER_URL=spark://spark-master:7077

# ============ Iceberg ============
ICEBERG_WAREHOUSE=s3a://warehouse/
HIVE_METASTORE_URI=thrift://hive-metastore:9083

# ============ Superset admin ============
SUPERSET_ADMIN=admin
SUPERSET_ADMIN_PASSWORD=admin
SUPERSET_SECRET_KEY=change_me_to_a_random_secret
